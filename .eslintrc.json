{
  "extends": [
    "@rocketseat/eslint-config/next",
    "prettier"
  ],
  "plugins": [
    "prettier"
  ],
  "rules": {
    "no-unused-vars": "off",
    "camelcase": "off",
    "unknownAtRules": "off",
    "no-var": "off",
    "@typescript-eslint/no-unused-vars": "off",
    "prettier/prettier": ["error", {
      "semi": true,
      "singleQuote": false,
      "endOfLine": "auto"
    }],
    "linebreak-style": 0 
  }
}
